---
import type { ModuleGroup, Lesson, Track } from '../lib/content';
import { getQuizFor } from '../lib/content';
import type { LockInfo } from '../lib/lockClient';

interface Props {
  track: Track;
  currentModuleSlug: string;
  group: ModuleGroup;
  currentLessonId: string;
}
const { track, group, currentLessonId } = Astro.props;
const base = import.meta.env.BASE_URL;

function isCurrent(l: Lesson) {
  return l.id === currentLessonId;
}

const lockInfo: LockInfo = await Promise.all(
  group.submodules.map((sub) =>
    Promise.all(
      sub.lessons.map(async (lesson) => ({
        id: lesson.id,
        hasQuiz: !!(await getQuizFor(lesson))?.data.questions.length,
      })),
    ),
  ),
);
---

<nav class="tree" style="padding: var(--cl-space-4) 0;" aria-label="Danh sách bài trong module">
  <div class="tree-mod">{group.name}</div>

  {group.lessons.map((lesson) => (
    <a href={`${base}${lesson.id}/`} data-lesson-nav={lesson.id} title={lesson.data.title} class={`tree-lesson ${isCurrent(lesson) ? 'active' : ''}`}>
      <span data-nav-dot={lesson.id} class="dot dot-todo"></span>
      <span>{lesson.data.title}</span>
    </a>
  ))}

  {group.submodules.map((sub, subIndex) => (
    <div data-submodule-section={subIndex} class="transition-opacity">
      <div class="tree-sec" style={subIndex > 0 ? 'margin-top: 10px' : ''}>{sub.name}</div>
      {sub.lessons.map((lesson) => (
        <a href={`${base}${lesson.id}/`} data-lesson-nav={lesson.id} title={lesson.data.title} class={`tree-lesson ${isCurrent(lesson) ? 'active' : ''}`}>
          <span data-nav-dot={lesson.id} class="dot dot-todo"></span>
          <span>{lesson.data.title}</span>
        </a>
      ))}
    </div>
  ))}

  <a href={`${base}${track}/${group.slug}/`} style="display: block; margin: var(--cl-space-4) var(--cl-space-3) 0; font-size: 12px; color: color-mix(in srgb, var(--cl-text) 55%, transparent);">
    ← Quay lại module
  </a>
</nav>

<script is:inline define:vars={{ lockInfo }}>
  window.__sidebarLockInfo = lockInfo;
</script>
<script>
  import { getProgress } from '../lib/progress';
  import { applySubmoduleLocks } from '../lib/lockClient';

  function syncNavDots() {
    document.querySelectorAll<HTMLElement>('[data-nav-dot]').forEach((el) => {
      const id = el.dataset.navDot!;
      const state = getProgress(id);
      const done = state === 'quiz_done' || state === 'completed' || state === 'viewed';
      el.classList.toggle('dot-done', done);
      el.classList.toggle('dot-todo', !done);
    });
  }

  syncNavDots();
  window.addEventListener('ai-learn-progress-change', syncNavDots);

  const lockInfo = (window as any).__sidebarLockInfo as { id: string; hasQuiz: boolean }[][];
  if (lockInfo) {
    document.querySelectorAll<HTMLElement>('nav[aria-label="Danh sách bài trong module"]').forEach((nav) => {
      applySubmoduleLocks(nav, lockInfo);
    });
  }
</script>
