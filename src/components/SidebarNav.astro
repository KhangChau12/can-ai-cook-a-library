---
import type { ModuleGroup, Lesson, Track } from '../lib/content';

interface Props {
  track: Track;
  currentModuleSlug: string;
  group: ModuleGroup;
  currentLessonId: string;
}
const { track, group, currentLessonId } = Astro.props;
const base = import.meta.env.BASE_URL;

function isCurrent(l: Lesson) {
  return l.id === currentLessonId;
}
---

<nav class="flex h-full flex-col overflow-y-auto p-4" aria-label="Danh sách bài trong module">
  <a href={`${base}#${track}`} class="mb-3 inline-flex items-center gap-1.5 text-[12px] font-semibold text-text-disabled transition hover:text-text-tertiary">
    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
    Danh sách module
  </a>

  <a href={`${base}${track}/${group.slug}/`} class="mb-1 block rounded-md px-2 py-1.5 text-[13.5px] font-bold text-text-primary transition hover:bg-bg-elevated">
    {group.name}
  </a>

  <div class="mt-1 flex flex-col gap-0.5">
    {group.lessons.map((lesson) => (
      <a
        href={`${base}${lesson.id}/`}
        data-lesson-nav={lesson.id}
        class={`flex items-center gap-2 rounded-md px-2.5 py-1.5 text-[13px] transition ${
          isCurrent(lesson) ? 'bg-primary-blue/10 font-semibold text-text-primary' : 'text-text-tertiary hover:bg-bg-elevated hover:text-text-secondary'
        }`}
      >
        <span data-nav-dot={lesson.id} class="h-1.5 w-1.5 shrink-0 rounded-full border border-border-subtle"></span>
        <span class="truncate">{lesson.data.title}</span>
      </a>
    ))}

    {group.submodules.map((sub) => (
      <div class="mt-3">
        <div class="px-2.5 py-1 text-[11px] font-bold uppercase tracking-wide text-text-disabled">{sub.name}</div>
        {sub.lessons.map((lesson) => (
          <a
            href={`${base}${lesson.id}/`}
            data-lesson-nav={lesson.id}
            class={`flex items-center gap-2 rounded-md px-2.5 py-1.5 text-[13px] transition ${
              isCurrent(lesson) ? 'bg-primary-blue/10 font-semibold text-text-primary' : 'text-text-tertiary hover:bg-bg-elevated hover:text-text-secondary'
            }`}
          >
            <span data-nav-dot={lesson.id} class="h-1.5 w-1.5 shrink-0 rounded-full border border-border-subtle"></span>
            <span class="truncate">{lesson.data.title}</span>
          </a>
        ))}
      </div>
    ))}
  </div>
</nav>

<script>
  import { getProgress } from '../lib/progress';
  document.querySelectorAll<HTMLElement>('[data-nav-dot]').forEach((el) => {
    const id = el.dataset.navDot!;
    const state = getProgress(id);
    if (state === 'quiz_done') el.classList.add('bg-success', 'border-success');
    else if (state === 'viewed') el.classList.add('bg-accent-blue', 'border-accent-blue');
  });
</script>
