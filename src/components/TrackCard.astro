---
import ProgressRing from './ProgressRing.astro';
import type { Track } from '../lib/content';

interface Props {
  track: Track;
  title: string;
  description: string;
  lessonCount: number;
  moduleCount: number;
  accent: 'blue' | 'cyan';
}

const { track, title, description, lessonCount, moduleCount, accent } = Astro.props;
const base = import.meta.env.BASE_URL;

const accentClasses = {
  blue: {
    ring: 'from-primary-blue to-accent-blue',
    glow: 'group-hover:shadow-[0_0_0_1px_rgba(37,99,235,0.4),0_20px_50px_-20px_rgba(37,99,235,0.45)]',
    chip: 'bg-primary-blue/10 text-accent-blue border-primary-blue/25',
  },
  cyan: {
    ring: 'from-accent-cyan to-accent-cyan-bright',
    glow: 'group-hover:shadow-[0_0_0_1px_rgba(6,182,212,0.4),0_20px_50px_-20px_rgba(6,182,212,0.45)]',
    chip: 'bg-accent-cyan/10 text-accent-cyan-bright border-accent-cyan/25',
  },
}[accent];
---

<a
  href={`${base}${track}/`}
  data-track-card={track}
  data-total={lessonCount}
  class={`group relative flex flex-col justify-between overflow-hidden rounded-2xl border border-border-default bg-bg-surface p-7 transition-all duration-200 hover:-translate-y-1 hover:border-border-subtle ${accentClasses.glow} sm:p-9`}
>
  <div class={`pointer-events-none absolute -right-16 -top-16 h-56 w-56 rounded-full bg-gradient-to-br ${accentClasses.ring} opacity-[0.07] blur-2xl transition-opacity group-hover:opacity-[0.14]`}></div>

  <div class="relative">
    <span class={`inline-flex items-center gap-1.5 rounded-full border px-2.5 py-1 text-[11px] font-bold uppercase tracking-wide ${accentClasses.chip}`}>
      {moduleCount} module
    </span>
    <h2 class="mt-4 text-2xl font-extrabold tracking-tight text-text-primary sm:text-[26px]">{title}</h2>
    <p class="mt-3 max-w-md text-[14.5px] leading-relaxed text-text-tertiary">{description}</p>
  </div>

  <div class="relative mt-8 flex items-center justify-between border-t border-border-default pt-5">
    <div class="font-mono text-[13px] text-text-disabled">
      <span class="font-bold text-text-secondary">{lessonCount}</span> bài học
    </div>
    <ProgressRing ratio={0} size={38} strokeWidth={3.5} data-track-progress={track} />
  </div>
</a>
