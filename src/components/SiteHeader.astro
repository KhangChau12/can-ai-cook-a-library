---
import SearchOverlay from './SearchOverlay.astro';
const base = import.meta.env.BASE_URL;
---

<header class="sticky top-0 z-30 border-b border-border-default/80 bg-bg-primary/85 backdrop-blur">
  <div class="mx-auto flex max-w-6xl items-center gap-4 px-5 py-3.5">
    <a href={base} class="flex items-center gap-2 text-sm font-extrabold tracking-tight text-text-primary">
      <span class="h-2 w-2 rounded-full bg-gradient-to-br from-accent-blue to-accent-cyan-bright shadow-[0_0_10px_rgba(59,130,246,0.6)]"></span>
      Can AI Cook a Library?
    </a>
    <div class="ml-auto">
      <button
        id="search-trigger"
        type="button"
        class="flex items-center gap-2 rounded-lg border border-border-default bg-bg-inset px-3 py-1.5 text-xs text-text-disabled transition hover:border-border-subtle hover:text-text-tertiary"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <span class="hidden md:inline">Tìm bài viết…</span>
        <kbd class="hidden rounded border border-border-subtle bg-bg-elevated px-1.5 py-0.5 font-mono text-[10px] md:inline">/</kbd>
      </button>
    </div>
  </div>
</header>

<SearchOverlay />
