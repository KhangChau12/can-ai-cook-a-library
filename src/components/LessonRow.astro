---
import type { Lesson } from '../lib/content';
import { estimateReadingMinutes } from '../lib/content';

interface Props {
  lesson: Lesson;
  index: number;
}
const { lesson, index } = Astro.props;
const base = import.meta.env.BASE_URL;
const isDraftish = lesson.data.status && lesson.data.status !== 'stable';
const minutes = estimateReadingMinutes(lesson);
---

<a
  href={`${base}${lesson.id}/`}
  data-lesson-row={lesson.id}
  class="lesson-row flex items-center gap-3 border-t border-border-default px-4 py-3 text-inherit no-underline transition first:border-t-0 hover:bg-bg-inset"
>
  <span
    data-lesson-check={lesson.id}
    class="flex h-5.5 w-5.5 shrink-0 items-center justify-center rounded-full border-[1.5px] border-border-subtle text-[11px] font-bold text-text-tertiary"
  >
    {index + 1}
  </span>
  <span class="min-w-0 flex-1">
    <span class="flex items-start justify-between gap-3">
      <span class="font-heading truncate text-[14.5px] font-semibold leading-snug text-text-primary">{lesson.data.title}</span>
      {isDraftish && (
        <span class="mt-0.5 shrink-0 rounded-full border border-warning/25 bg-warning/10 px-2 py-0.5 text-[10px] font-bold uppercase tracking-wide text-warning">
          {lesson.data.status}
        </span>
      )}
    </span>
  </span>
  <span class="shrink-0 text-[12px] font-semibold text-text-disabled">{minutes} phút</span>
</a>
