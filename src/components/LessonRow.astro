---
import type { Lesson } from '../lib/content';
import { lessonUrl } from '../lib/content';

interface Props {
  lesson: Lesson;
  index: number;
}
const { lesson, index } = Astro.props;
const base = import.meta.env.BASE_URL;
const isDraftish = lesson.data.status && lesson.data.status !== 'stable';
---

<a
  href={`${base}${lesson.id}/`}
  data-lesson-row={lesson.id}
  class="group flex items-start gap-4 rounded-lg px-3 py-3 transition hover:bg-bg-surface"
>
  <span class="mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-md bg-bg-elevated font-mono text-[11px] font-bold text-text-tertiary group-hover:bg-primary-blue group-hover:text-white">
    {index + 1}
  </span>
  <span
    data-lesson-check={lesson.id}
    class="mt-1.5 h-2 w-2 shrink-0 rounded-full border border-border-subtle"
  ></span>
  <span class="min-w-0 flex-1">
    <span class="block text-[14.5px] font-semibold leading-snug text-text-primary">{lesson.data.title}</span>
    {lesson.data.summary && (
      <span class="mt-0.5 line-clamp-1 block text-[12.5px] text-text-disabled">{lesson.data.summary}</span>
    )}
  </span>
  {isDraftish && (
    <span class="mt-1 shrink-0 rounded-full border border-warning/25 bg-warning/10 px-2 py-0.5 text-[10px] font-bold uppercase tracking-wide text-warning">
      {lesson.data.status}
    </span>
  )}
</a>
