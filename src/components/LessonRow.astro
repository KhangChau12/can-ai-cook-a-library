---
import type { Lesson } from '../lib/content';
import { lessonUrl } from '../lib/content';

interface Props {
  lesson: Lesson;
  index: number;
}
const { lesson, index } = Astro.props;
const base = import.meta.env.BASE_URL;
const isDraftish = lesson.data.status && lesson.data.status !== 'stable';
---

<a
  href={`${base}${lesson.id}/`}
  data-lesson-row={lesson.id}
  class="group flex items-start gap-4 rounded-lg px-3 py-3.5 transition hover:bg-bg-surface"
>
  <span
    data-lesson-check={lesson.id}
    class="mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-full border border-border-subtle font-mono text-[11px] font-bold text-text-tertiary"
  >
    {index + 1}
  </span>
  <span class="min-w-0 flex-1">
    <span class="flex items-start justify-between gap-3">
      <span class="truncate text-[14.5px] font-semibold leading-snug text-text-primary">{lesson.data.title}</span>
      {isDraftish && (
        <span class="mt-0.5 shrink-0 rounded-full border border-warning/25 bg-warning/10 px-2 py-0.5 text-[10px] font-bold uppercase tracking-wide text-warning">
          {lesson.data.status}
        </span>
      )}
    </span>
    {lesson.data.summary && (
      <span class="mt-1 block truncate text-[12.5px] text-text-tertiary">{lesson.data.summary}</span>
    )}
  </span>
</a>
