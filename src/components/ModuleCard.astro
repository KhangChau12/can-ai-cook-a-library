---
import type { ModuleGroup, Track } from '../lib/content';
import { LEVEL_LABELS, trackLabel, totalReadingMinutes } from '../lib/content';

interface Props {
  track: Track;
  group: ModuleGroup;
  showTrackChip?: boolean;
}
const { track, group, showTrackChip = false } = Astro.props;
const base = import.meta.env.BASE_URL;

const totalLessons = group.lessons.length + group.submodules.reduce((n, s) => n + s.lessons.length, 0);
const totalMinutes = totalReadingMinutes([...group.lessons, ...group.submodules.flatMap((s) => s.lessons)]);
const sectionCount = group.submodules.length;

const levelDotCount: Record<string, number> = { foundation: 1, intermediate: 2, advanced: 3 };
const activeDots = levelDotCount[group.level] ?? 1;
---

<a href={`${base}${track}/${group.slug}/`} data-module-card={`${track}/${group.slug}`} class="course-card">
  <span class="card-kicker">
    {totalLessons} bài{sectionCount > 0 ? ` · ${sectionCount} phần` : ''}
    <span class="level-dots">
      {Array.from({ length: 3 }).map((_, i) => <span class={i >= activeDots ? 'off' : ''}></span>)}
    </span>
    {showTrackChip && <span class="tag tag-neutral">{trackLabel(track)}</span>}
  </span>

  <span class="tag tag-outline w-max">{LEVEL_LABELS[group.level]}</span>

  <h3 class="card-title">{group.name}</h3>

  <p class="card-body line-clamp-2">{group.meta?.description}</p>

  <div class="progress-track">
    <div data-module-progress-fill={`${track}/${group.slug}`} data-total={totalLessons} class="progress-fill" style="width: 0%"></div>
  </div>
  <span data-module-progress-label={`${track}/${group.slug}`} class="card-meta">Chưa bắt đầu · ~{totalMinutes} phút</span>
</a>
