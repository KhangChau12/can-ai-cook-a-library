---
import type { Heading } from '../lib/renderMarkdown';

interface Props {
  headings: Heading[];
}
const { headings } = Astro.props;
---

{headings.length > 0 && (
  <nav class="sticky top-20" aria-label="Mục lục bài viết">
    <div style="font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; color: color-mix(in srgb, var(--cl-text) 55%, transparent); margin-bottom: var(--cl-space-2);">
      Mục lục
    </div>
    {headings.map((h) => (
      <a href={`#${h.id}`} data-toc-link={h.id} class="toc-item" style={h.depth === 3 ? 'padding-left: calc(var(--cl-space-3) * 2)' : ''}>
        {h.text}
      </a>
    ))}
  </nav>
)}

<script>
  const links = document.querySelectorAll<HTMLAnchorElement>('[data-toc-link]');
  if (links.length) {
    const headingEls = Array.from(links)
      .map((l) => document.getElementById(l.dataset.tocLink!))
      .filter((el): el is HTMLElement => !!el);

    const setActive = (id: string) => {
      links.forEach((l) => {
        l.classList.toggle('active', l.dataset.tocLink === id);
      });
    };

    const observer = new IntersectionObserver(
      (entries) => {
        const visible = entries.filter((e) => e.isIntersecting);
        if (visible.length > 0) setActive(visible[0].target.id);
      },
      { rootMargin: '-80px 0px -70% 0px' },
    );
    headingEls.forEach((el) => observer.observe(el));
  }
</script>
