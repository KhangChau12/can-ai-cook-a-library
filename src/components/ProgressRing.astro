---
interface Props {
  /** value 0-1 */
  ratio: number;
  size?: number;
  strokeWidth?: number;
  class?: string;
}
const { ratio, size = 40, strokeWidth = 4, class: className = '' } = Astro.props;
const r = (size - strokeWidth) / 2;
const circumference = 2 * Math.PI * r;
const offset = circumference * (1 - Math.min(1, Math.max(0, ratio)));
const pct = Math.round(ratio * 100);
---

<div class={`relative inline-flex shrink-0 items-center justify-center ${className}`} style={`width:${size}px;height:${size}px`} data-progress-ring>
  <svg width={size} height={size} viewBox={`0 0 ${size} ${size}`} class="-rotate-90">
    <circle cx={size / 2} cy={size / 2} r={r} fill="none" stroke="var(--color-bg-elevated)" stroke-width={strokeWidth} />
    <circle
      data-ring-progress
      cx={size / 2}
      cy={size / 2}
      r={r}
      fill="none"
      stroke="url(#ring-gradient)"
      stroke-width={strokeWidth}
      stroke-linecap="round"
      stroke-dasharray={circumference}
      stroke-dashoffset={offset}
      style="transition: stroke-dashoffset 0.4s ease"
    />
    <defs>
      <linearGradient id="ring-gradient" x1="0" y1="0" x2="1" y2="1">
        <stop offset="0%" stop-color="var(--color-accent-blue)" />
        <stop offset="100%" stop-color="var(--color-accent-cyan-bright)" />
      </linearGradient>
    </defs>
  </svg>
  <span data-ring-label class="absolute font-mono text-[10px] font-bold text-text-tertiary">{pct}%</span>
</div>
