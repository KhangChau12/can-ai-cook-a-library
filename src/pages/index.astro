---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import ModuleCard from '../components/ModuleCard.astro';
import { getHomeSections, LEVEL_LABELS } from '../lib/content';

const { examGroups, byLevel } = await getHomeSections();
const levels = (['foundation', 'intermediate', 'advanced'] as const).map((level) => ({
  level,
  label: LEVEL_LABELS[level],
  groups: byLevel[level],
}));

const levelHint: Record<string, string> = {
  foundation: 'Xuất phát điểm — không cần biết gì trước.',
  intermediate: 'Cần nắm nền tảng toán & DL trước khi vào đây.',
  advanced: 'Xây trên cả một module khác — đọc kỹ prerequisites từng bài.',
};
---

<BaseLayout title="Trang chủ" description="Thư viện bài học AI/ML song ngữ Việt, viết bởi Claude Code chạy autopilot.">
  <SiteHeader />

  <main class="mx-auto max-w-6xl px-5 py-16 sm:py-20">
    <div class="relative mx-auto max-w-2xl text-center">
      <div
        class="pointer-events-none absolute left-1/2 top-1/2 -z-10 h-105 w-155 -translate-x-1/2 -translate-y-1/2 rounded-full blur-3xl"
        style="background: radial-gradient(circle, rgba(37,99,235,0.15) 0%, rgba(6,182,212,0.12) 45%, transparent 70%);"
      ></div>
      <h1 class="font-display mt-5 text-4xl tracking-tight text-text-primary sm:text-5xl">
        Can AI Cook a Library?
      </h1>
      <p class="mt-4 text-[15.5px] leading-relaxed text-text-tertiary">
        Một thư viện bài học AI/ML song ngữ Việt — từ Linear Regression tới Transformer,
        LLM và Reinforcement Learning hiện đại. Xếp theo cấp độ để bạn biết nên học gì trước.
      </p>
    </div>

    <div class="mt-10 flex flex-col gap-14 sm:mt-14">
      {examGroups.length > 0 && (
        <section id="exam-track">
          <div class="mb-5 flex items-baseline justify-between gap-3">
            <h2 class="font-heading flex items-center gap-2.5 text-xl font-extrabold tracking-tight text-text-primary">
              Bổ trợ thi đấu
            </h2>
            <span class="text-[12.5px] text-text-disabled">Áp dụng ngay vào bài nộp thật trên The Noders platform.</span>
          </div>
          <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
            {examGroups.map((group) => (
              <ModuleCard track={group.track} group={group} />
            ))}
          </div>
        </section>
      )}
      {levels.map(({ level, label, groups }) => groups.length > 0 && (
        <section>
          <div class="mb-5 flex items-baseline justify-between gap-3">
            <h2 class="font-heading flex items-center gap-2.5 text-xl font-extrabold tracking-tight text-text-primary">
              {label}
            </h2>
            <span class="text-[12.5px] text-text-disabled">{levelHint[level]}</span>
          </div>
          <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
            {groups.map((group) => (
              <ModuleCard track={group.track} group={group} />
            ))}
          </div>
        </section>
      ))}
    </div>
  </main>

  <script>
    import { getAllProgress } from '../lib/progress';

    const progress = getAllProgress();
    document.querySelectorAll<HTMLElement>('[data-module-dots]').forEach((wrap) => {
      const key = wrap.dataset.moduleDots!;
      const total = parseInt(wrap.dataset.total || '0', 10);
      const ids = Object.keys(progress).filter((id) => id.startsWith(`${key}/`) && progress[id] !== 'unread');
      const dots = wrap.querySelectorAll<HTMLElement>('[data-dot]');
      const shownTotal = dots.length;
      const doneScaled = total > 0 ? Math.round((ids.length / total) * shownTotal) : 0;
      dots.forEach((dot, i) => {
        if (i < doneScaled) {
          dot.classList.remove('bg-bg-elevated');
          dot.classList.add('bg-accent-blue');
        }
      });
    });
  </script>
</BaseLayout>
