---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SiteHeader from '../../../components/SiteHeader.astro';
import { getModuleGroups, getQuizFor, trackLabel, estimateReadingMinutes, totalReadingMinutes, LEVEL_LABELS, type Track } from '../../../lib/content';
import type { LockInfo } from '../../../lib/lockClient';

export async function getStaticPaths() {
  const tracks: Track[] = ['exam-track', 'foundations-track'];
  const paths = [];
  for (const track of tracks) {
    const groups = await getModuleGroups(track);
    for (const group of groups) {
      paths.push({ params: { track, module: group.slug }, props: { group, track } });
    }
  }
  return paths;
}

const { group, track } = Astro.props as { group: Awaited<ReturnType<typeof getModuleGroups>>[number]; track: Track };
const base = import.meta.env.BASE_URL;
const totalLessons = group.lessons.length + group.submodules.reduce((n, s) => n + s.lessons.length, 0);
const allGroupLessons = [...group.lessons, ...group.submodules.flatMap((s) => s.lessons)];
const totalMinutes = totalReadingMinutes(allGroupLessons);
const firstLesson = allGroupLessons[0];

// LockInfo for gating: one entry per submodule (in display order), each
// lesson tagged with whether it has a quiz (needed by isLessonComplete).
const lockInfo: LockInfo = await Promise.all(
  group.submodules.map((sub) =>
    Promise.all(
      sub.lessons.map(async (lesson) => ({
        id: lesson.id,
        hasQuiz: !!(await getQuizFor(lesson))?.data.questions.length,
      })),
    ),
  ),
);

// Flat lesson list (module has no submodules) is rendered as a single
// pseudo-section so it uses the same .sec-card markup as real submodules.
const sections =
  group.submodules.length > 0
    ? group.submodules
    : group.lessons.length > 0
      ? [{ name: group.name, slug: group.slug, lessons: group.lessons, description: undefined }]
      : [];
---

<BaseLayout title={group.name}>
  <SiteHeader />

  <div class="page-wrap">
    <div style="padding: var(--cl-space-4) var(--cl-space-6) 0">
      <div class="crumb">
        <a href={base}>Trang chủ</a> / <a href={`${base}#${track}`}>{trackLabel(track)}</a> / {group.name}
      </div>
    </div>

    <div class="layout-grid">
      <aside class="info-card" style="position: sticky; top: var(--cl-space-4); align-self: start;">
        <div style="display: flex; align-items: center; gap: 6px; flex-wrap: wrap;">
          <span class="tag tag-neutral">{LEVEL_LABELS[group.level]}</span>
          <span class="tag tag-outline">{trackLabel(track)}</span>
        </div>
        <h1 style="font-family: var(--cl-font-heading); font-weight: 800; font-size: 24px; letter-spacing: -0.01em; margin: 0;">{group.name}</h1>
        <hr class="hr" style="margin: var(--cl-space-1) 0;" />
        <div style="display: flex; align-items: center; gap: var(--cl-space-3);">
          <div class="ring" data-module-ring={`${track}/${group.slug}`} style="background: conic-gradient(var(--cl-accent) 0deg, var(--cl-divider) 0deg);">
            <div data-module-ring-label={`${track}/${group.slug}`} style="width: 56px; height: 56px; border-radius: 50%; background: var(--cl-bg); display: flex; align-items: center; justify-content: center; font-feature-settings: 'tnum' 1; color: var(--cl-text);">0%</div>
          </div>
          <div>
            <div data-module-progress-count={`${track}/${group.slug}`} data-total={totalLessons} style="font-family: var(--cl-font-heading); font-weight: 700; font-size: 15px; font-feature-settings: 'tnum' 1; color: var(--cl-text);">0 / {totalLessons} bài</div>
            <div style="font-size: 12px; color: color-mix(in srgb, var(--cl-text) 55%, transparent);">{group.submodules.length > 0 ? `${group.submodules.length} phần · ` : ''}~{totalMinutes} phút</div>
          </div>
        </div>
        {group.meta?.description && (
          <p style="font-family: var(--cl-font-body); font-style: italic; font-size: 13px; line-height: 1.55; color: color-mix(in srgb, var(--cl-text) 72%, transparent); margin: 0;">{group.meta.description}</p>
        )}
        {firstLesson && (
          <a data-module-cta={`${track}/${group.slug}`} href={`${base}${firstLesson.id}/`} class="btn btn-primary btn-block">
            Bắt đầu học →
          </a>
        )}
      </aside>

      <div>
        {sections.map((sub, subIndex) => (
          <div class="sec-card" style="margin-bottom: var(--cl-space-4);" id={sub.slug} data-submodule-section={subIndex}>
            <div class="sec-card-head">
              <span style="font-family: var(--cl-font-heading); font-weight: 700; font-size: 15px; color: var(--cl-accent);">{String(subIndex + 1).padStart(2, '0')}</span>
              <h3 style="font-family: var(--cl-font-heading); font-weight: 700; font-size: 16px; margin: 0; flex: 1;" title={sub.name}>{sub.name}</h3>
              <span data-submodule-count={`${track}/${group.slug}`} data-submodule-index={subIndex} data-total={sub.lessons.length} style="font-size: 12px; color: color-mix(in srgb, var(--cl-text) 55%, transparent);">
                0/{sub.lessons.length}
              </span>
            </div>
            {sub.lessons.map((lesson) => (
              <a class="lesson-row" href={`${base}${lesson.id}/`} data-lesson-row={lesson.id}>
                <span class="status-dot status-todo" data-lesson-check={lesson.id}></span>
                <div style="flex: 1;">
                  <div style="font-family: var(--cl-font-heading); font-weight: 600; font-size: 14px; color: var(--cl-text);">{lesson.data.title}</div>
                </div>
                <span style="font-size: 12px; color: color-mix(in srgb, var(--cl-text) 50%, transparent);">{estimateReadingMinutes(lesson)} phút</span>
              </a>
            ))}
          </div>
        ))}
      </div>
    </div>
  </div>

  <script is:inline define:vars={{ lockInfo }}>
    window.__lockInfo = lockInfo;
  </script>
  <script>
    import { getAllProgress, isLessonComplete } from '../../../lib/progress';
    import { applySubmoduleLocks } from '../../../lib/lockClient';

    document.querySelectorAll<HTMLElement>('[data-lesson-check]').forEach((el) => {
      const id = el.dataset.lessonCheck!;
      const progress = getAllProgress();
      const state = progress[id];
      el.classList.remove('status-todo');
      if (state === 'quiz_done' || state === 'completed') {
        el.classList.add('status-done');
        el.textContent = '✓';
      } else if (state === 'viewed') {
        el.classList.add('status-progress');
        el.textContent = '●';
      } else {
        el.classList.add('status-todo');
      }
    });

    const progress = getAllProgress();
    const ring = document.querySelector<HTMLElement>('[data-module-ring]');
    const countEl = document.querySelector<HTMLElement>('[data-module-progress-count]');
    if (ring && countEl) {
      const key = ring.dataset.moduleRing!;
      const total = parseInt(countEl.dataset.total || '0', 10);
      const done = Object.keys(progress).filter((id) => id.startsWith(`${key}/`) && progress[id] !== 'unread').length;
      const pct = total > 0 ? Math.round((done / total) * 100) : 0;
      ring.style.background = `conic-gradient(var(--cl-accent) ${pct * 3.6}deg, var(--cl-divider) 0deg)`;
      countEl.textContent = `${done} / ${total} bài`;
      const ringLabel = document.querySelector<HTMLElement>(`[data-module-ring-label="${key}"]`);
      if (ringLabel) ringLabel.textContent = `${pct}%`;
    }

    document.querySelectorAll<HTMLElement>('[data-submodule-count]').forEach((el) => {
      const subIdx = Number(el.dataset.submoduleIndex);
      const lockInfo = (window as any).__lockInfo as { id: string; hasQuiz: boolean }[][];
      const lessons = lockInfo?.[subIdx] ?? [];
      const done = lessons.filter((l) => isLessonComplete(l.id, l.hasQuiz)).length;
      el.textContent = done === lessons.length && lessons.length > 0 ? `${done}/${lessons.length} ✓` : `${done}/${lessons.length}`;
    });

    const lockInfo = (window as any).__lockInfo as { id: string; hasQuiz: boolean }[][];
    if (lockInfo) {
      applySubmoduleLocks(document, lockInfo);
    }
  </script>
</BaseLayout>
