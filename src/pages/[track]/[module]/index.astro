---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SiteHeader from '../../../components/SiteHeader.astro';
import LessonRow from '../../../components/LessonRow.astro';
import { getModuleGroups, getQuizFor, trackLabel, totalReadingMinutes, LEVEL_LABELS, type Track } from '../../../lib/content';
import type { LockInfo } from '../../../lib/lockClient';

export async function getStaticPaths() {
  const tracks: Track[] = ['exam-track', 'foundations-track'];
  const paths = [];
  for (const track of tracks) {
    const groups = await getModuleGroups(track);
    for (const group of groups) {
      paths.push({ params: { track, module: group.slug }, props: { group, track } });
    }
  }
  return paths;
}

const { group, track } = Astro.props as { group: Awaited<ReturnType<typeof getModuleGroups>>[number]; track: Track };
const base = import.meta.env.BASE_URL;
const totalLessons = group.lessons.length + group.submodules.reduce((n, s) => n + s.lessons.length, 0);
const allGroupLessons = [...group.lessons, ...group.submodules.flatMap((s) => s.lessons)];
const totalMinutes = totalReadingMinutes(allGroupLessons);

// LockInfo for gating: one entry per submodule (in display order), each
// lesson tagged with whether it has a quiz (needed by isLessonComplete).
const lockInfo: LockInfo = await Promise.all(
  group.submodules.map((sub) =>
    Promise.all(
      sub.lessons.map(async (lesson) => ({
        id: lesson.id,
        hasQuiz: !!(await getQuizFor(lesson))?.data.questions.length,
      })),
    ),
  ),
);

const levelClasses: Record<string, string> = {
  foundation: 'border-success/25 bg-success/10 text-success',
  intermediate: 'border-primary-blue/25 bg-primary-blue/10 text-accent-blue',
  advanced: 'border-warning/25 bg-warning/10 text-warning',
};
---

<BaseLayout title={group.name}>
  <SiteHeader />

  <main class="mx-auto max-w-4xl px-5 py-12 sm:py-16">
    <nav class="mb-6 flex flex-wrap items-center gap-2 text-[12.5px] text-text-disabled">
      <a href={base} class="transition hover:text-text-tertiary">Trang chủ</a>
      <span>/</span>
      <a href={`${base}#${track}`} class="transition hover:text-text-tertiary">{trackLabel(track)}</a>
      <span>/</span>
      <span class="text-text-tertiary">{group.name}</span>
    </nav>

    <div class="mb-10 border-b border-border-default pb-8">
      <div class="flex flex-wrap items-center gap-2">
        <span class={`inline-flex items-center rounded-full border px-2.5 py-0.5 text-[10.5px] font-bold uppercase tracking-wide ${levelClasses[group.level]}`}>
          {LEVEL_LABELS[group.level]}
        </span>
        <span class="text-[12px] font-semibold text-text-disabled">{trackLabel(track)}</span>
      </div>
      <h1 class="font-heading mt-3 text-4xl font-bold tracking-tight text-text-primary">{group.name}</h1>
      {group.meta?.description && (
        <p class="mt-3 max-w-2xl text-[16px] leading-relaxed text-text-tertiary">{group.meta.description}</p>
      )}

      <div class="mt-6 flex flex-wrap items-center gap-4">
        <div class="h-2 flex-1 max-w-xs overflow-hidden rounded-full bg-bg-elevated">
          <div data-module-progress-bar={`${track}/${group.slug}`} data-total={totalLessons} class="h-full w-0 rounded-full bg-primary-blue transition-all duration-500"></div>
        </div>
        <span data-module-progress-label={`${track}/${group.slug}`} class="font-mono text-[12.5px] font-bold text-text-tertiary">0 / {totalLessons} bài</span>
        <span class="inline-flex items-center gap-1.5 text-[12px] font-semibold text-text-disabled">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          ~{totalMinutes} phút đọc tổng
        </span>
      </div>
    </div>

    {group.lessons.length > 0 && (
      <div class="mb-12">
        <div class="flex flex-col">
          {group.lessons.map((lesson, i) => <LessonRow lesson={lesson} index={i} />)}
        </div>
      </div>
    )}

    {group.submodules.length > 0 && (
      <div class="flex flex-col gap-6">
        {group.submodules.map((sub, subIndex) => (
          <section id={sub.slug} class="scroll-mt-20 rounded-xl border border-border-default bg-bg-surface/40 p-5 transition-opacity" data-submodule-section={subIndex}>
            <div class="mb-3 flex items-center gap-2.5 border-b border-border-default pb-3">
              <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-md bg-primary-blue font-mono text-[12px] font-extrabold text-white">
                {subIndex + 1}
              </span>
              <h2 class="min-w-0 truncate text-[15px] font-bold uppercase tracking-wide text-text-primary" title={sub.name}>{sub.name}</h2>
              <div class="ml-auto flex shrink-0 items-center gap-2">
                <div class="h-1.5 w-16 overflow-hidden rounded-full bg-bg-elevated">
                  <div
                    data-submodule-progress-bar={`${track}/${group.slug}`}
                    data-submodule-index={subIndex}
                    data-total={sub.lessons.length}
                    class="h-full w-0 rounded-full bg-primary-blue transition-all duration-500"
                  ></div>
                </div>
                <span class="font-mono text-[11px] font-semibold text-text-disabled">{sub.lessons.length} bài</span>
              </div>
            </div>
            <div class="flex flex-col">
              {sub.lessons.map((lesson, i) => <LessonRow lesson={lesson} index={i} />)}
            </div>
          </section>
        ))}
      </div>
    )}
  </main>

  <script define:vars={{ lockInfo }}>
    window.__lockInfo = lockInfo;
  </script>
  <script>
    import { getProgress, getAllProgress } from '../../../lib/progress';
    import { applySubmoduleLocks } from '../../../lib/lockClient';

    document.querySelectorAll<HTMLElement>('[data-lesson-check]').forEach((el) => {
      const id = el.dataset.lessonCheck!;
      const state = getProgress(id);
      if (state === 'quiz_done' || state === 'completed') {
        el.classList.add('border-transparent', 'bg-success', 'text-white');
      } else if (state === 'viewed') {
        el.classList.add('border-transparent', 'bg-accent-blue', 'text-white');
      }
    });

    const progress = getAllProgress();
    const bar = document.querySelector<HTMLElement>('[data-module-progress-bar]');
    const label = document.querySelector<HTMLElement>('[data-module-progress-label]');
    if (bar) {
      const key = bar.dataset.moduleProgressBar!;
      const total = parseInt(bar.dataset.total || '0', 10);
      const done = Object.keys(progress).filter((id) => id.startsWith(`${key}/`) && progress[id] !== 'unread').length;
      const pct = total > 0 ? Math.round((done / total) * 100) : 0;
      bar.style.width = `${pct}%`;
      if (label) label.textContent = `${done} / ${total} bài`;
    }

    const lockInfo = (window as any).__lockInfo as { id: string; hasQuiz: boolean }[][];
    if (lockInfo) {
      document.querySelectorAll<HTMLElement>('[data-submodule-progress-bar]').forEach((subBar) => {
        const subIdx = Number(subBar.dataset.submoduleIndex);
        const lessons = lockInfo[subIdx] ?? [];
        const total = lessons.length;
        const done = lessons.filter((l) => progress[l.id] === 'quiz_done' || progress[l.id] === 'completed').length;
        const pct = total > 0 ? Math.round((done / total) * 100) : 0;
        subBar.style.width = `${pct}%`;
      });

      applySubmoduleLocks(document, lockInfo);
    }
  </script>
</BaseLayout>
