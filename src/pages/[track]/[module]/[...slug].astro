---
import LessonLayout from '../../../layouts/LessonLayout.astro';
import QuizIsland from '../../../components/QuizIsland';
import MarkCompleteButton from '../../../components/MarkCompleteButton';
import {
  getModuleGroups,
  getPrevNext,
  getQuizFor,
  estimateReadingMinutes,
  type Track,
  type Lesson,
} from '../../../lib/content';
import type { LockInfo } from '../../../lib/lockClient';

export async function getStaticPaths() {
  const tracks: Track[] = ['exam-track', 'foundations-track'];
  const paths = [];
  for (const track of tracks) {
    const groups = await getModuleGroups(track);
    for (const group of groups) {
      const allLessons: Lesson[] = [...group.lessons, ...group.submodules.flatMap((s) => s.lessons)];
      for (const lesson of allLessons) {
        // id shape: track/moduleSlug/[submoduleSlug/]lessonSlug — strip
        // the leading track/moduleSlug (already matched by [track]/[module])
        // to get the rest-param slug.
        const rest = lesson.id.split('/').slice(2);
        paths.push({
          params: { track, module: group.slug, slug: rest.join('/') },
          props: { lesson, group, track },
        });
      }
    }
  }
  return paths;
}

const { lesson, group, track } = Astro.props as {
  lesson: Lesson;
  group: Awaited<ReturnType<typeof getModuleGroups>>[number];
  track: Track;
};

const { prev, next } = await getPrevNext(track, lesson.id);
const quiz = await getQuizFor(lesson);
const hasQuiz = !!quiz && quiz.data.questions.length > 0;
const base = import.meta.env.BASE_URL;

// Which submodule (if any) this lesson belongs to, plus lock info for the
// whole module — used by LessonLayout to show a "this submodule isn't
// unlocked yet" banner when a locked lesson is opened directly via URL.
const currentSubmoduleIndex = group.submodules.findIndex((sub) => sub.lessons.some((l) => l.id === lesson.id));
const currentSubmodule = currentSubmoduleIndex >= 0 ? group.submodules[currentSubmoduleIndex] : undefined;
const lockInfo: LockInfo = await Promise.all(
  group.submodules.map((sub) =>
    Promise.all(
      sub.lessons.map(async (l) => ({
        id: l.id,
        hasQuiz: !!(await getQuizFor(l))?.data.questions.length,
      })),
    ),
  ),
);

const readingMinutes = estimateReadingMinutes(lesson);
---

<LessonLayout
  track={track}
  group={group}
  lesson={lesson}
  headings={lesson.data.headings ?? []}
  lockInfo={lockInfo}
  currentSubmoduleIndex={currentSubmoduleIndex}
>
  <span class="tag tag-outline">
    {currentSubmodule ? `Phần ${String(currentSubmoduleIndex + 1).padStart(2, '0')} · ${currentSubmodule.name}` : group.name}
  </span>
  <h1 style="font-family: var(--cl-font-heading); font-weight: 800; font-size: 34px; letter-spacing: -0.015em; margin: var(--cl-space-3) 0 var(--cl-space-2); color: var(--cl-text);">
    {lesson.data.title}
  </h1>
  {lesson.data.summary && (
    <p style="font-family: var(--cl-font-body); font-style: italic; font-size: 16px; color: color-mix(in srgb, var(--cl-text) 70%, transparent); margin: 0 0 var(--cl-space-2);">
      {lesson.data.summary}
    </p>
  )}
  <div style="font-size: 12.5px; color: color-mix(in srgb, var(--cl-text) 55%, transparent); margin-bottom: var(--cl-space-6);">
    ⏱ ~{readingMinutes} phút đọc
  </div>

  <article id="lesson-article" class="reading" set:html={lesson.data.html} />

  {hasQuiz ? (
    <div class="quiz-card">
      <div style="display: flex; align-items: center; gap: 8px; margin-bottom: var(--cl-space-2);">
        <span class="tag tag-outline">✓ Kiểm tra nhanh</span>
        <span style="font-size: 12px; color: color-mix(in srgb, var(--cl-text) 55%, transparent); margin-left: auto;">{quiz!.data.questions.length} câu</span>
      </div>
      <QuizIsland client:load lessonId={lesson.id} questions={quiz!.data.questions} />
    </div>
  ) : (
    <MarkCompleteButton client:load lessonId={lesson.id} />
  )}

  <hr class="hr" style="margin: var(--cl-space-6) 0 var(--cl-space-4);" />
  <div style="display: flex; justify-content: space-between; gap: var(--cl-space-4);">
    {prev ? (
      <a href={`${base}${prev.id}/`} class="btn btn-secondary">← Trọn bộ module</a>
    ) : <span></span>}
    {next ? (
      <a href={`${base}${next.id}/`} data-next-link={lesson.id} data-has-quiz={String(hasQuiz)} class="btn btn-primary">
        <span data-next-label>Bài tiếp theo →</span>
      </a>
    ) : <span></span>}
  </div>
</LessonLayout>

<div id="scroll-progress-track" class="fixed inset-x-0 top-0 z-40 h-[3px] bg-transparent">
  <div id="scroll-progress-bar" class="h-full w-0 transition-[width] duration-100" style="background: var(--cl-accent);"></div>
</div>

<script>
  import { isLessonComplete } from '../../../lib/progress';

  const bar = document.getElementById('scroll-progress-bar');
  const article = document.getElementById('lesson-article');
  function updateScrollProgress() {
    if (!bar || !article) return;
    const rect = article.getBoundingClientRect();
    const total = rect.height - window.innerHeight + rect.top;
    const scrolled = -rect.top;
    const pct = total > 0 ? Math.min(100, Math.max(0, (scrolled / total) * 100)) : 0;
    bar.style.width = `${pct}%`;
  }
  document.addEventListener('scroll', updateScrollProgress, { passive: true });
  updateScrollProgress();

  const nextLink = document.querySelector<HTMLAnchorElement>('[data-next-link]');
  if (nextLink) {
    const id = nextLink.dataset.nextLink!;
    const hasQuiz = nextLink.dataset.hasQuiz === 'true';
    const label = nextLink.querySelector<HTMLElement>('[data-next-label]');
    const defaultLabel = label?.textContent ?? '';

    function syncNextLinkState() {
      if (!nextLink || !label) return;
      if (isLessonComplete(id, hasQuiz)) {
        nextLink.classList.remove('opacity-70');
        label.textContent = defaultLabel;
      } else {
        nextLink.classList.add('opacity-70');
        label.textContent = hasQuiz ? 'Làm quiz để tiếp tục →' : 'Đánh dấu hoàn thành để tiếp tục →';
      }
    }

    syncNextLinkState();
    window.addEventListener('ai-learn-progress-change', syncNextLinkState);
  }
</script>
