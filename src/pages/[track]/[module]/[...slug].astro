---
import { getCollection } from 'astro:content';
import LessonLayout from '../../../layouts/LessonLayout.astro';
import QuizIsland from '../../../components/QuizIsland';
import {
  getModuleGroups,
  getModuleGroup,
  getPrevNext,
  getQuizFor,
  trackLabel,
  type Track,
  type Lesson,
} from '../../../lib/content';

export async function getStaticPaths() {
  const tracks: Track[] = ['exam-track', 'foundations-track'];
  const paths = [];
  for (const track of tracks) {
    const groups = await getModuleGroups(track);
    for (const group of groups) {
      const allLessons: Lesson[] = [...group.lessons, ...group.submodules.flatMap((s) => s.lessons)];
      for (const lesson of allLessons) {
        // id shape: track/moduleSlug/[submoduleSlug/]lessonSlug — strip
        // the leading track/moduleSlug (already matched by [track]/[module])
        // to get the rest-param slug.
        const rest = lesson.id.split('/').slice(2);
        paths.push({
          params: { track, module: group.slug, slug: rest.join('/') },
          props: { lesson, group, track },
        });
      }
    }
  }
  return paths;
}

const { lesson, group, track } = Astro.props as {
  lesson: Lesson;
  group: Awaited<ReturnType<typeof getModuleGroups>>[number];
  track: Track;
};

const { prev, next } = await getPrevNext(track, lesson.id);
const quiz = await getQuizFor(lesson);
const base = import.meta.env.BASE_URL;
---

<LessonLayout track={track} group={group} lesson={lesson} headings={lesson.data.headings ?? []}>
  <nav class="mb-6 flex flex-wrap items-center gap-2 text-[12.5px] text-text-disabled">
    <a href={base} class="transition hover:text-text-tertiary">Trang chủ</a>
    <span>/</span>
    <a href={`${base}#${track}`} class="transition hover:text-text-tertiary">{trackLabel(track)}</a>
    <span>/</span>
    <a href={`${base}${track}/${group.slug}/`} class="transition hover:text-text-tertiary">{group.name}</a>
  </nav>

  <header class="mb-8 border-b border-border-default pb-7">
    <h1 class="font-display text-[26px] leading-tight tracking-tight text-text-primary sm:text-[30px]">
      {lesson.data.title}
    </h1>
    {lesson.data.summary && (
      <p class="mt-3.5 text-[14.5px] italic leading-relaxed text-text-tertiary">{lesson.data.summary}</p>
    )}
  </header>

  {quiz && quiz.data.questions.length > 0 ? (
    <div id="tab-panels">
      <div class="mb-7 inline-flex gap-1 rounded-xl border border-border-default bg-bg-inset p-1">
        <button type="button" data-tab-btn="content" class="rounded-lg bg-[linear-gradient(135deg,#2563EB_0%,#06B6D4_100%)] px-4 py-2 text-[13px] font-bold text-white transition" data-active="true">
          Nội dung bài
        </button>
        <button type="button" data-tab-btn="quiz" class="rounded-lg px-4 py-2 text-[13px] font-bold text-text-tertiary transition hover:text-text-secondary">
          Quiz ({quiz.data.questions.length} câu)
        </button>
      </div>

      <div data-tab-panel="content">
        <article class="prose max-w-none prose-headings:font-bold prose-headings:tracking-tight prose-pre:bg-bg-inset prose-pre:border prose-pre:border-border-default" set:html={lesson.data.html} />
      </div>
      <div data-tab-panel="quiz" class="hidden">
        <QuizIsland client:visible lessonId={lesson.id} questions={quiz.data.questions} />
      </div>
    </div>
  ) : (
    <article class="prose prose-invert max-w-none prose-headings:font-bold prose-headings:tracking-tight prose-a:text-accent-cyan-bright prose-code:text-[#7dd3fc] prose-pre:bg-bg-inset prose-pre:border prose-pre:border-border-default" set:html={lesson.data.html} />
  )}

  <nav class="mt-14 grid grid-cols-1 gap-3 sm:grid-cols-2">
    {prev ? (
      <a href={`${base}${prev.id}/`} class="flex flex-col gap-1 rounded-xl border border-border-default bg-bg-surface px-5 py-4 transition hover:-translate-y-0.5 hover:border-border-subtle">
        <span class="text-[10.5px] font-bold uppercase tracking-wide text-text-disabled">← Trước</span>
        <span class="truncate text-[13.5px] font-bold text-text-primary">{prev.data.title}</span>
      </a>
    ) : <span></span>}
    {next ? (
      <a href={`${base}${next.id}/`} class="flex flex-col items-end gap-1 rounded-xl border border-border-default bg-bg-surface px-5 py-4 text-right transition hover:-translate-y-0.5 hover:border-border-subtle">
        <span class="text-[10.5px] font-bold uppercase tracking-wide text-text-disabled">Tiếp →</span>
        <span class="truncate text-[13.5px] font-bold text-text-primary">{next.data.title}</span>
      </a>
    ) : <span></span>}
  </nav>
</LessonLayout>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('[data-tab-btn]');
  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const target = btn.dataset.tabBtn!;
      buttons.forEach((b) => {
        const active = b === btn;
        b.dataset.active = String(active);
        b.classList.toggle('bg-[linear-gradient(135deg,#2563EB_0%,#06B6D4_100%)]', active);
        b.classList.toggle('text-white', active);
        b.classList.toggle('text-text-tertiary', !active);
      });
      document.querySelectorAll('[data-tab-panel]').forEach((panel) => {
        panel.classList.toggle('hidden', panel.getAttribute('data-tab-panel') !== target);
      });
    });
  });
</script>
