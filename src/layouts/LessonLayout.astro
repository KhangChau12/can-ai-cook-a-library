---
import BaseLayout from './BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SidebarNav from '../components/SidebarNav.astro';
import TableOfContents from '../components/TableOfContents.astro';
import type { Heading } from '../lib/renderMarkdown';
import type { ModuleGroup, Track, Lesson } from '../lib/content';
import type { LockInfo } from '../lib/lockClient';

interface Props {
  track: Track;
  group: ModuleGroup;
  lesson: Lesson;
  headings: Heading[];
  lockInfo?: LockInfo;
  currentSubmoduleIndex?: number;
}
const { track, group, lesson, headings, lockInfo = [], currentSubmoduleIndex = -1 } = Astro.props;
---

<BaseLayout title={lesson.data.title} description={lesson.data.summary}>
  <SiteHeader>
    <span slot="crumb" class="hidden truncate text-[12.5px] text-text-disabled sm:inline">
      <a href={`${import.meta.env.BASE_URL}${track}/${group.slug}/`} class="no-underline transition hover:text-text-tertiary">{group.name}</a>
      <span class="mx-1">/</span>
      <span class="text-text-tertiary">{lesson.data.title}</span>
    </span>
  </SiteHeader>

  <div class="fixed bottom-5 right-5 z-40 flex flex-col items-end gap-2.5 lg:hidden">
    {headings.length > 0 && (
      <button
        type="button"
        id="mobile-toc-trigger"
        class="flex items-center gap-2 rounded-full border border-border-subtle bg-bg-elevated px-4 py-3 text-[13px] font-bold text-text-primary shadow-lg shadow-black/30"
        aria-label="Mở mục lục bài viết"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="8" y1="6" x2="20" y2="6"/><line x1="8" y1="12" x2="20" y2="12"/><line x1="8" y1="18" x2="20" y2="18"/><circle cx="4" cy="6" r="1.3" fill="currentColor" stroke="none"/><circle cx="4" cy="12" r="1.3" fill="currentColor" stroke="none"/><circle cx="4" cy="18" r="1.3" fill="currentColor" stroke="none"/></svg>
        Mục lục
      </button>
    )}
    <button
      type="button"
      id="mobile-nav-trigger"
      class="flex items-center gap-2 rounded-full border border-border-subtle bg-bg-elevated px-4 py-3 text-[13px] font-bold text-text-primary shadow-lg shadow-black/30"
      aria-label="Mở danh sách bài học"
    >
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" y1="6" x2="20" y2="6"/><line x1="4" y1="12" x2="20" y2="12"/><line x1="4" y1="18" x2="20" y2="18"/></svg>
      Danh sách bài
    </button>
  </div>

  <div id="mobile-nav-overlay" class="fixed inset-0 z-50 hidden bg-black/60 backdrop-blur-sm lg:hidden">
    <div class="ml-auto flex h-full w-[85vw] max-w-[320px] flex-col bg-bg-primary shadow-2xl">
      <div class="flex items-center justify-between border-b border-border-default px-4 py-3">
        <span class="text-[13px] font-bold text-text-primary">Danh sách bài</span>
        <button type="button" id="mobile-nav-close" class="rounded-md p-1.5 text-text-tertiary hover:bg-bg-elevated hover:text-text-primary" aria-label="Đóng">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>
      <div class="min-h-0 flex-1">
        <SidebarNav track={track} currentModuleSlug={group.slug} group={group} currentLessonId={lesson.id} />
      </div>
    </div>
  </div>

  {headings.length > 0 && (
    <div id="mobile-toc-overlay" class="fixed inset-0 z-50 hidden bg-black/60 backdrop-blur-sm lg:hidden">
      <div class="mr-auto flex h-full w-[85vw] max-w-[320px] flex-col bg-bg-primary shadow-2xl">
        <div class="flex items-center justify-between border-b border-border-default px-4 py-3">
          <span class="text-[13px] font-bold text-text-primary">Mục lục bài viết</span>
          <button type="button" id="mobile-toc-close" class="rounded-md p-1.5 text-text-tertiary hover:bg-bg-elevated hover:text-text-primary" aria-label="Đóng">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
          </button>
        </div>
        <div class="min-h-0 flex-1 overflow-y-auto px-5 py-4">
          <ul class="flex flex-col">
            {headings.map((h) => (
              <li>
                <a
                  href={`#${h.id}`}
                  data-mobile-toc-link
                  class={`block border-l-2 border-transparent py-2 text-[13.5px] text-text-tertiary transition hover:text-text-secondary ${h.depth === 3 ? 'pl-6' : 'pl-3'}`}
                >
                  {h.text}
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  )}

  <div class="lesson-body mx-auto max-w-350">
    <aside class="tree-nav sticky top-14.25 hidden h-[calc(100vh-57px)] overflow-y-auto lg:block" style="border-right: 1px solid var(--cl-divider);">
      <SidebarNav track={track} currentModuleSlug={group.slug} group={group} currentLessonId={lesson.id} />
    </aside>

    <main class="min-w-0 overflow-y-auto px-4 py-8 sm:px-8 sm:py-10 lg:px-10 lg:py-12">
      <div id="lock-banner" class="mb-6 hidden items-center gap-2 rounded px-4 py-3 text-[13px] font-semibold" style="border: 1px solid var(--cl-divider); background: var(--cl-neutral-100); color: var(--cl-accent);">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="shrink-0"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        <span>Bạn đang xem trước bài thuộc submodule chưa mở khoá — nên hoàn thành các submodule trước để nắm nền tảng.</span>
      </div>
      <div class="mb-4 flex items-center justify-end gap-1">
        <span class="mr-1 text-[11px] font-semibold" style="color: color-mix(in srgb, var(--cl-text) 55%, transparent)">Cỡ chữ</span>
        <button type="button" id="font-scale-down" class="btn btn-secondary" style="width: 28px; height: 28px; padding: 0; font-size: 12px;" aria-label="Giảm cỡ chữ">A-</button>
        <button type="button" id="font-scale-up" class="btn btn-secondary" style="width: 28px; height: 28px; padding: 0; font-size: 12px;" aria-label="Tăng cỡ chữ">A+</button>
      </div>
      <div id="lesson-content-col" style="font-size: var(--reading-font-scale, 1em)">
        <slot />
      </div>
    </main>

    <aside class="toc-aside hidden lg:block" style="border-left: 1px solid var(--cl-divider); padding: var(--cl-space-6) var(--cl-space-4); overflow-y: auto;">
      <TableOfContents headings={headings} />
    </aside>
  </div>

  <script define:vars={{ lessonId: lesson.id, lockInfo, currentSubmoduleIndex }} data-mark-viewed>
    window.__lessonId = lessonId;
    window.__lessonLockInfo = lockInfo;
    window.__currentSubmoduleIndex = currentSubmoduleIndex;
  </script>
  <script>
    import { markViewed } from '../lib/progress';
    import { firstIncompleteSubmoduleIndex } from '../lib/lockClient';

    const id = (window as any).__lessonId as string | undefined;
    if (id) markViewed(id);

    const lockInfo = (window as any).__lessonLockInfo as { id: string; hasQuiz: boolean }[][];
    const currentSubmoduleIndex = (window as any).__currentSubmoduleIndex as number;
    if (lockInfo && lockInfo.length > 0 && currentSubmoduleIndex >= 0) {
      const firstIncomplete = firstIncompleteSubmoduleIndex(lockInfo);
      if (currentSubmoduleIndex > firstIncomplete) {
        document.getElementById('lock-banner')?.classList.remove('hidden');
        document.getElementById('lock-banner')?.classList.add('flex');
      }
    }

    const FONT_SCALE_KEY = 'ai-learn-font-scale';
    const contentCol = document.getElementById('lesson-content-col');
    const steps = [0.9, 1, 1.1, 1.2, 1.3];
    function applyScale(scale: number) {
      contentCol?.style.setProperty('--reading-font-scale', `${scale}em`);
      try {
        localStorage.setItem(FONT_SCALE_KEY, String(scale));
      } catch {
        /* storage unavailable */
      }
    }
    let current = 1;
    try {
      const saved = parseFloat(localStorage.getItem(FONT_SCALE_KEY) || '1');
      if (steps.includes(saved)) current = saved;
    } catch {
      /* storage unavailable */
    }
    applyScale(current);
    document.getElementById('font-scale-up')?.addEventListener('click', () => {
      const idx = Math.min(steps.length - 1, steps.indexOf(current) + 1);
      current = steps[idx];
      applyScale(current);
    });
    document.getElementById('font-scale-down')?.addEventListener('click', () => {
      const idx = Math.max(0, steps.indexOf(current) - 1);
      current = steps[idx];
      applyScale(current);
    });
  </script>
  <script>
    const trigger = document.getElementById('mobile-nav-trigger');
    const overlay = document.getElementById('mobile-nav-overlay');
    const closeBtn = document.getElementById('mobile-nav-close');

    function openNav() {
      overlay?.classList.remove('hidden');
      document.body.classList.add('overflow-hidden');
    }
    function closeNav() {
      overlay?.classList.add('hidden');
      document.body.classList.remove('overflow-hidden');
    }

    trigger?.addEventListener('click', openNav);
    closeBtn?.addEventListener('click', closeNav);
    overlay?.addEventListener('click', (e) => {
      if (e.target === overlay) closeNav();
    });
    overlay?.querySelectorAll('a').forEach((a) => a.addEventListener('click', closeNav));
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeNav();
    });
  </script>
  <script>
    const tocTrigger = document.getElementById('mobile-toc-trigger');
    const tocOverlay = document.getElementById('mobile-toc-overlay');
    const tocClose = document.getElementById('mobile-toc-close');

    function openToc() {
      tocOverlay?.classList.remove('hidden');
      document.body.classList.add('overflow-hidden');
    }
    function closeToc() {
      tocOverlay?.classList.add('hidden');
      document.body.classList.remove('overflow-hidden');
    }

    tocTrigger?.addEventListener('click', openToc);
    tocClose?.addEventListener('click', closeToc);
    tocOverlay?.addEventListener('click', (e) => {
      if (e.target === tocOverlay) closeToc();
    });
    tocOverlay?.querySelectorAll('a').forEach((a) => a.addEventListener('click', closeToc));
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeToc();
    });
  </script>
</BaseLayout>
